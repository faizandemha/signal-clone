# SQLite file path (relative to backend/)
DATABASE_URL=sqlite:///./signal_clone.db

# Comma separated list of allowed origins for CORS (add your deployed frontend URL)
CORS_ORIGINS=http://localhost:3000

# Fixed mock OTP used for registrations/logins that AREN'T sent a real email
# (i.e. username-style identifiers, like the seeded demo accounts alice/bob/...)
MOCK_OTP=123456

# --- Real email OTP (optional) ---
# Leave SMTP_USER/SMTP_PASSWORD blank to keep everything mocked (MOCK_OTP above).
# To send real codes: register with an email address instead of a username, and
# fill these in with a Gmail account + an "App Password" (NOT your normal Gmail
# password): https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be turned on for the Google account.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Signal Clone

# Note: phone-number registration/login is fully supported (see the login
# screen), it just always uses the mocked code above rather than a real text
# - there's no SMS provider configured here by design.

# --- Attachments ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=15
